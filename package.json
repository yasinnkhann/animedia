		"husky": "^9.0.11",
		"lint-staged": "^15.2.2",
		"postcss": "^8.4.16",
		"prettier": "^3.2.5",
		"prettier-plugin-tailwindcss": "^0.5.13",
		"prisma": "^7.8.0",
		"tailwind-scrollbar": "^3.1.0",
		"tailwind-scrollbar-hide": "^1.1.7",
