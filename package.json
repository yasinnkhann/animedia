		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@types/comma-number": "^2.1.0",
		"@types/lodash": "^4.17.0",
		"@types/micro-cors": "^0.1.2",
		"@types/node": "25.6.2",
		"@types/nodemailer": "^6.4.7",
