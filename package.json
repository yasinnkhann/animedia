{
  "name": "animedia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "yarn run generate:prisma && next dev",
    "dev:inspect": "yarn run generate:prisma && NODE_OPTIONS='--inspect=0' next dev",
    "build": "yarn run generate:prisma && prisma db push --accept-data-loss && next build",
    "start": "next start",
    "studio": "npx prisma studio",
    "generate:prisma": "prisma generate",
    "connect:dev-supabase": "supabase start",
    "disconnect:dev-supabase": "supabase stop",
    "migrate:prod-to-local": "supabase db dump > supabase/dump-schema.sql && supabase db dump --data-only > supabase/dump-data.sql",
    "gen-env-types": "gen-env-types .env -o types/env.d.ts -e . && yarn prettier --write types/env.d.ts",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.42",
    "@hookform/resolvers": "^5.4.0",
    "@next-auth/prisma-adapter": "^1.0.7",
