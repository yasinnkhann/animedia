		"@sentry/nextjs": "^10.52.0",
		"@vercel/analytics": "^2.0.1",
		"all-iso-language-codes": "^1.0.21",
		"antd": "^6.3.7",
		"apollo-server-micro": "^3.13.0",
		"argon2": "^0.44.0",
		"comma-number": "^2.1.0",
		"formik": "^2.4.9",
		"framer-motion": "^12.38.0",
		"graphql": "^16.14.0",
		"graphql-middleware": "^6.1.35",
		"graphql-request": "^7.4.0",
		"graphql-scalars": "^1.25.0",
		"graphql-shield": "^7.6.5",
		"ioredis": "^5.10.1",
		"lodash": "^4.18.1",
		"micro": "^10.0.1",
		"micro-cors": "^0.1.1",
		"moment": "^2.30.1",
		"moment-timezone": "^0.6.2",
		"next": "^16.2.6",
		"next-auth": "^4.24.14",
		"nexus": "^1.3.0",
		"nodemailer": "^8.0.7",
		"react": "^19.2.6",
		"react-circular-progressbar": "^2.2.0",
		"react-dom": "^19.2.6",
		"react-horizontal-scrolling-menu": "^8.2.0",
		"react-hot-toast": "^2.6.0",
		"react-icons": "^5.6.0",
		"react-loading-icons": "^1.1.0",
		"rxjs": "^7.8.2",
