    "@types/nodemailer": "^6.4.7",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@types/tinycolor2": "^1.4.3",
    "@types/unidecode": "^0.1.1",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.11",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.6",
