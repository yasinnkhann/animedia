    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.52.0",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.207",
    "all-iso-language-codes": "^1.0.21",
    "argon2": "^0.44.0",
    "comma-number": "^2.1.0",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "lodash": "^4.18.1",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.7",
    "react": "^19.2.6",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.79.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-loading-icons": "^1.1.0",
    "recharts": "^3.8.1",
    "rxjs": "^7.8.2",
    "tinycolor2": "^1.6.0",
    "unidecode": "^1.1.0",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
