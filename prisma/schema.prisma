generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  created_at    DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  movie         Movie[]
  show          Show[]
  game          Game[]
  followers     Follows[] @relation("following")
  following     Follows[] @relation("follower")
  activities    Activity[]
  reviews       Review[]
  collections   Collection[] @relation("CollectionOwner")
  collaborations Collection[] @relation("CollectionCollaborators")
  NotificationsReceived Notification[] @relation("UserNotifications")
  NotificationsSent     Notification[] @relation("NotificationSender")
}

model Follows {
  followerId  String @map("follower_id")
  followingId String @map("following_id")
  follower    User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  created_at  DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Movie {
  id     String
  name   String
  status WatchStatus
  rating Int?
  image  String?
  release_date String?
  userId String      @map("user_id")
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([id, userId])
  @@index([userId], map: "Movie_user_id_idx")
}

model Show {
  id              String
  name            String
  current_episode Int         @default(0)
  status          WatchStatus
  rating          Int?
  image           String?
  release_date    String?
  total_episodes  Int?
  userId          String      @map("user_id")
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([id, userId])
  @@index([userId], map: "Show_user_id_idx")
}

model Game {
  id     String
  name   String
  rating Int?
  wishlist Boolean @default(false)
  image  String?
  release_date String?
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([id, userId])
  @@index([userId], map: "Game_user_id_idx")
}

enum WatchStatus {
  NOT_WATCHING
  WATCHING
  PLAN_TO_WATCH
  COMPLETED
  ON_HOLD
  DROPPED
}

model Activity {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ActivityType
  mediaType   MediaType
  mediaId     String
  mediaTitle  String
  mediaImage  String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([createdAt])
}

enum ActivityType {
  ADDED
  RATED
  STATUS_CHANGED
}

enum MediaType {
  MOVIE
  SHOW
  GAME
}

model Review {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType   MediaType
  mediaId     String
  mediaTitle  String
  mediaImage  String?
  content     String    @db.Text
  rating      Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([mediaType, mediaId])
}

model Collection {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  user        User             @relation("CollectionOwner", fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isPublic    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       CollectionItem[]
  collaborators User[]         @relation("CollectionCollaborators")

  @@index([userId])
}

model CollectionItem {
  id            String     @id @default(cuid())
  collectionId  String     @map("collection_id")
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  mediaType     MediaType
  mediaId       String
  mediaTitle    String
  mediaImage    String?
  watched       Boolean    @default(false)
  addedAt       DateTime   @default(now())

  @@unique([collectionId, mediaType, mediaId])
  @@index([collectionId])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id") // Recipient
  user        User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  senderId    String?          @map("sender_id") // Sender
  sender      User?            @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  type        NotificationType
  mediaId     String?
  mediaType   MediaType?
  mediaTitle  String?
  mediaImage  String?
  message     String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([userId])
}

enum NotificationType {
  RECOMMENDATION
  FOLLOW
  COLLECTION_INVITE
}
